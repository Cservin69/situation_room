# Rust
/target
/code
**/*.rs.bk
Cargo.lock.bak

# Runtime data — DuckDB files, archived articles, exports
/data/cache/*
/data/archive/*
/data/exports/*
!/data/cache/.gitkeep
!/data/archive/.gitkeep
!/data/exports/.gitkeep

# Secrets
.env
.env.local
*.pem
*.key

# Frontend (Tauri)
node_modules
dist
.svelte-kit
build

# Tauri build outputs
src-tauri/target
src-tauri/WixTools

# IDE
.idea
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.iml

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Version control
clean_code.zip
situation_room_codebase.txt
situation_room_delta_*.zip
stockpile_codebase.txt
stockpile_delta_*.zip

# Misc
*.swp
*.swo
*~
# DuckDB (database files contain user data, must not be committed)
*.duckdb
*.duckdb.wal
*.duckdb.tmp/

# Tauri-generated schemas and codegen — regenerated on every build
apps/desktop/src-tauri/gen/

# Per-session apply-instruction READMEs (live in tarballs, not the repo)
README_FIX*.md
README_PATCH*.md

# Stray ts-rs misroute (older builds put types under crates/apps by mistake;
# kept in case a stale checkout still has it. The fix is in
# crates/api/src/types_export.rs export_to paths.)
crates/apps/

# macOS-only
.AppleDouble
