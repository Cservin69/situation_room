# situation_room environment configuration.
#
# SECURITY NOTES:
#   - Copy this file to `.env` (gitignored). Never commit `.env`.
#   - Keys in this file are loaded into process env only. They are NOT
#     written to config files, logs, or disk by situation_room.
#   - situation_room rejects obvious placeholder values ("your-key",
#     "changeme", empty strings, keys under 16 chars).
#   - If you use a secrets manager (1Password CLI, direnv, macOS keychain),
#     export the variables in your shell instead of using this file.

# ---------------------------------------------------------------------------
# LLM provider selection
# ---------------------------------------------------------------------------
# Which provider the binaries use at boot. Default: "xai".
#   xai  | grok     -> XaiProvider (xAI Grok via OpenAI-compatible API)
#   anthropic | claude -> AnthropicProvider (Claude via Messages API)
# An unrecognised value aborts boot rather than silently falling
# back, so a typo here is loud, not silent.
LLM_PROVIDER=xai

# ---------------------------------------------------------------------------
# LLM provider keys (set the one matching LLM_PROVIDER)
# ---------------------------------------------------------------------------

# Anthropic (Claude). Required when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=your-anthropic-key-here

# Per-tier model overrides. Optional. Empty / unset = use the
# binary's defaults from AnthropicConfig::default. See
# https://docs.claude.com/en/docs/about-claude/models for the catalog.
# ANTHROPIC_FRONTIER_MODEL=
# ANTHROPIC_WORKHORSE_MODEL=
# ANTHROPIC_CHEAP_MODEL=

# Optional: pin to a specific Anthropic API version. Default is the
# stable long-supported "2023-06-01"; only set this if you need a
# pre-release feature gated behind a newer version string.
# ANTHROPIC_VERSION=

# xAI (Grok). Required when LLM_PROVIDER=xai (the default).
XAI_API_KEY=your-xai-key-here

# Per-tier model overrides for xAI. Same empty-string-as-unset
# semantics as the Anthropic overrides above. See
# https://docs.x.ai/api for the catalog.
# XAI_FRONTIER_MODEL=
# XAI_WORKHORSE_MODEL=
# XAI_CHEAP_MODEL=

# OpenAI / Google — provider stubs only at this time. The keys are
# accepted by .env loaders but no provider consumes them yet.
OPENAI_API_KEY=your-openai-key-here
GOOGLE_API_KEY=your-google-key-here

# ---------------------------------------------------------------------------
# Optional data source credentials
# ---------------------------------------------------------------------------
# UN Comtrade
COMTRADE_API_KEY=

# SEC EDGAR requires a descriptive User-Agent, not a key.
# Format: "Project-Name your-contact@example.com"
SEC_EDGAR_USER_AGENT=situation_room contributor@example.com

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
RUST_LOG=situation_room=info,warn

# Disable telemetry in transitive dependencies that send it opportunistically.
DO_NOT_TRACK=1
