# situation_room environment configuration.
#
# SECURITY NOTES:
#   - Copy this file to `.env` (gitignored). Never commit `.env`.
#   - Keys in this file are loaded into process env only. They are NOT
#     written to config files, logs, or disk by situation_room.
#   - situation_room rejects obvious placeholder values ("your-key",
#     "changeme", empty strings, keys under 16 chars).
#   - If you use a secrets manager (1Password CLI, direnv, macOS keychain),
#     export the variables in your shell instead of using this file.

# ---------------------------------------------------------------------------
# LLM providers (at least one required)
# ---------------------------------------------------------------------------

# Anthropic (Claude) — recommended.
ANTHROPIC_API_KEY=your-anthropic-key-here

# xAI (Grok)
XAI_API_KEY=your-xai-key-here

# OpenAI
OPENAI_API_KEY=your-openai-key-here

# Google (Gemini)
GOOGLE_API_KEY=your-google-key-here

# ---------------------------------------------------------------------------
# Optional data source credentials
# ---------------------------------------------------------------------------
# UN Comtrade
COMTRADE_API_KEY=

# SEC EDGAR requires a descriptive User-Agent, not a key.
# Format: "Project-Name your-contact@example.com"
SEC_EDGAR_USER_AGENT=situation_room contributor@example.com

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
RUST_LOG=situation_room=info,warn

# Disable telemetry in transitive dependencies that send it opportunistically.
DO_NOT_TRACK=1
